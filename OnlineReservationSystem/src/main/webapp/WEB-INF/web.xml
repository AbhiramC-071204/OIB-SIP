<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         version="5.0">

    <!-- Welcome File -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- Login -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.reservation.servlet.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/LoginServlet</url-pattern>
    </servlet-mapping>

    <!-- Reservation -->
    <servlet>
        <servlet-name>ReservationServlet</servlet-name>
        <servlet-class>com.reservation.servlet.ReservationServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ReservationServlet</servlet-name>
        <url-pattern>/ReservationServlet</url-pattern>
    </servlet-mapping>

   <servlet>
    <servlet-name>DeleteServlet</servlet-name>
    <servlet-class>com.reservation.servlet.DeleteServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>DeleteServlet</servlet-name>
    <url-pattern>/DeleteServlet</url-pattern>
</servlet-mapping>

    <!-- Train AJAX -->
    <servlet>
        <servlet-name>TrainServlet</servlet-name>
        <servlet-class>com.reservation.servlet.TrainServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>TrainServlet</servlet-name>
        <url-pattern>/TrainServlet</url-pattern>
    </servlet-mapping>

    <!-- PDF -->
    <servlet>
        <servlet-name>PDFServlet</servlet-name>
        <servlet-class>com.reservation.servlet.PDFServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>PDFServlet</servlet-name>
        <url-pattern>/PDFServlet</url-pattern>
    </servlet-mapping>

 


<servlet>
    <servlet-name>RegisterServlet</servlet-name>
    <servlet-class>com.reservation.servlet.RegisterServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>RegisterServlet</servlet-name>
    <url-pattern>/RegisterServlet</url-pattern>
</servlet-mapping>
</web-app>