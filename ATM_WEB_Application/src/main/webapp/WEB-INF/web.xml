</servlet>

<servlet-mapping>
    <servlet-name>Analytics</servlet-name>
    <url-pattern>/analytics</url-pattern>
</servlet-mapping>

    <servlet-mapping>
        <servlet-name>Logout</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

</web-app>