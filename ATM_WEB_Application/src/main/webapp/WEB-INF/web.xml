<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee" version="5.0">

<welcome-file-list>
    <welcome-file>index.jsp</welcome-file>
</welcome-file-list>

<!-- LOGIN -->
<servlet>
    <servlet-name>Login</servlet-name>
    <servlet-class>com.atm.servlet.LoginServlet</servlet-class>
</servlet>
<servlet-mapping>
    <servlet-name>Login</servlet-name>
    <url-pattern>/login</url-pattern>
</servlet-mapping>

<!-- REGISTER -->
<servlet>
    <servlet-name>Register</servlet-name>
    <servlet-class>com.atm.servlet.RegisterServlet</servlet-class>
</servlet>
<servlet-mapping>
    <servlet-name>Register</servlet-name>
    <url-pattern>/register</url-pattern>
</servlet-mapping>

<!-- DEPOSIT -->
<servlet>
    <servlet-name>Deposit</servlet-name>
    <servlet-class>com.atm.servlet.DepositServlet</servlet-class>
</servlet>
<servlet-mapping>
    <servlet-name>Deposit</servlet-name>
    <url-pattern>/deposit</url-pattern>
</servlet-mapping>

<!-- WITHDRAW -->
<servlet>
    <servlet-name>Withdraw</servlet-name>
    <servlet-class>com.atm.servlet.WithdrawServlet</servlet-class>
</servlet>
<servlet-mapping>
    <servlet-name>Withdraw</servlet-name>
    <url-pattern>/withdraw</url-pattern>
</servlet-mapping>

<!-- TRANSFER -->
<servlet>
    <servlet-name>Transfer</servlet-name>
    <servlet-class>com.atm.servlet.TransferServlet</servlet-class>
</servlet>
<servlet-mapping>
    <servlet-name>Transfer</servlet-name>
    <url-pattern>/transfer</url-pattern>
</servlet-mapping>

<!-- TRANSACTION -->
