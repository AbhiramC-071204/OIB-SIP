    <servlet-name>Transaction</servlet-name>
    <servlet-class>com.atm.servlet.TransactionServlet</servlet-class>
</servlet>
<servlet-mapping>
    <servlet-name>Transaction</servlet-name>
    <url-pattern>/history</url-pattern>
</servlet-mapping>

<!-- ANALYTICS -->
<servlet>
    <servlet-name>Analytics</servlet-name>
    <servlet-class>com.atm.servlet.AnalyticsServlet</servlet-class>
</servlet>
<servlet-mapping>
    <servlet-name>Analytics</servlet-name>
    <url-pattern>/analytics</url-pattern>
</servlet-mapping>

<!-- LOGOUT -->
<servlet>
    <servlet-name>Logout</servlet-name>
    <servlet-class>com.atm.servlet.LogoutServlet</servlet-class>
</servlet>
<servlet-mapping>
    <servlet-name>Logout</servlet-name>
    <url-pattern>/logout</url-pattern>
</servlet-mapping>

</web-app>